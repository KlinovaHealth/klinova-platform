# ── Supabase (required for all platform features) ────────────────────────────
# Find these in: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service key — SERVER SIDE ONLY.  Never expose to the browser.
# Used only in /api/admin/* routes for user-creation by admins.
# Find it in: supabase.com → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App URL (used for auth redirect links) ───────────────────────────────────
# Local: http://localhost:3000 | Production: https://app.klinova.co
NEXT_PUBLIC_APP_URL=http://localhost:3000
